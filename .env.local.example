# ── Sarvdev .env.local — copy this file and fill in your values ──────────────

# MongoDB (required)
MONGODB_URI="mongodb+srv://..."

# Auth token secret (required)
AUTH_TOKEN="sarvdev_secure_token_change_me"

# ── AI Spiritual Chatbot (Gemini) ─────────────────────────────────────────────
# Get free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@sarvdev.com"
# IMPORTANT: This MUST match VAPID_PUBLIC_KEY (accessible in browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ── Azure TTS (optional) ──────────────────────────────────────────────────────
AZURE_TTS_KEY=""
AZURE_TTS_REGION=""

# ── Google Analytics (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=""
